# S3 media storage — only needed in production (Lightsail Container Service
# has an ephemeral filesystem, so uploads must go to S3 to survive a deploy).
# Leave unset for local dev; uploads fall back to the local media/ folder.
# AWS_STORAGE_BUCKET_NAME=shwetanshu-website
# AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_CUSTOM_DOMAIN=
