<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} ^(www\.)?millerpiano\.com$ [NC]
  RewriteRule ^(.*)$ https://millerpiano.com/$1 [L,R=301]
  # Serve static and media files directly without going through Passenger
  RewriteCond %{REQUEST_URI} !^/static/
  RewriteCond %{REQUEST_URI} !^/media/
</IfModule>
